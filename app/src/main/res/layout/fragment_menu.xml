<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center">

    <RelativeLayout
        android:id="@+id/btnLivros"
        android:layout_width="128dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/botao_menu_shape"
        android:paddingVertical="12dp">

        <ImageView
            android:id="@+id/iconeLivro"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/iconelivro"
            />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/iconeLivro"
            android:layout_marginStart="12dp"
            android:text="Livros"
            android:textColor="@color/botao_texto"
            android:textSize="16sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/btnDados"
        android:layout_width="128dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/botao_menu_shape"
        android:paddingVertical="12dp">

        <ImageView
            android:id="@+id/iconeDado"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/iconedado" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/iconeDado"
            android:layout_marginStart="12dp"
            android:text="Dados"
            android:textColor="@color/botao_texto"
            android:textSize="16sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/btnFichas"
        android:layout_width="128dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/botao_menu_shape"
        android:paddingVertical="12dp">

        <ImageView
            android:id="@+id/iconeFicha"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/iconeficha" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/iconeFicha"
            android:layout_marginStart="12dp"
            android:text="Fichas"
            android:textColor="@color/botao_texto"
            android:textSize="16sp"
            android:textStyle="bold" />

    </RelativeLayout>

</LinearLayout>