<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:paddingHorizontal="20dp"
    android:paddingVertical="16dp">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/txtResultado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/cor_primaria"
                android:textSize="40sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtDetalhamento"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text=""
                android:textColor="@color/cor_primaria"
                android:textStyle="bold"
                android:textSize="12sp"
                android:gravity="center" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerPendentes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:text="Bônus"
                    android:textColor="@color/cor_texto_secundario"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/btnModificadorMenos"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/botao_circular_shape"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="–"
                    android:textColor="@color/botao_texto"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtModificador"
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    android:background="@android:color/transparent"
                    android:gravity="center"
                    android:importantForAutofill="no"
                    android:inputType="numberSigned"
                    android:maxLength="4"
                    android:text="+0"
                    android:textColor="@color/cor_primaria"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnModificadorMais"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/botao_circular_shape"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="@color/botao_texto"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnRolarPendentes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/botao_menu_shape"
                android:paddingHorizontal="32dp"
                android:paddingVertical="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rolar"
                    android:textColor="@color/botao_texto"
                    android:textStyle="bold"
                    android:textSize="16sp" />
            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerDados"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="2"
        android:layout_marginStart="20dp"
        android:clipToPadding="false" />

</LinearLayout>